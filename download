package edu.creditrisk;

import weka.classifiers.Classifier;
import weka.classifiers.trees.RandomForest;
import weka.classifiers.trees.J48;
import weka.classifiers.functions.SMO;
import weka.classifiers.Evaluation;
import weka.core.Instances;
import java.util.Random;

public class SupervisedRunner {

    public static void evaluateClassifiers(Instances data) throws Exception {
        if (data.classIndex() == -1) data.setClassIndex(data.numAttributes() - 1);

        Classifier rf = new RandomForest();
        Classifier j48 = new J48();
        Classifier smo = new SMO();

        int folds = 10;
        Random rand = new Random(1);

        evaluate("RandomForest", rf, data, folds, rand);
        evaluate("J48", j48, data, folds, rand);
        evaluate("SMO", smo, data, folds, rand);
    }

    private static void evaluate(String name, Classifier cls, Instances data, int folds, Random rand) throws Exception {
        System.out.println("=== Evaluating: " + name + " ===");
        Evaluation eval = new Evaluation(data);
        eval.crossValidateModel(cls, data, folds, rand);
        System.out.printf("Accuracy: %.4f\n", (1 - eval.errorRate()));
        System.out.printf("Precision (macro): %.4f\n", eval.weightedPrecision());
        System.out.printf("Recall (macro): %.4f\n", eval.weightedRecall());
        System.out.printf("F1 (macro): %.4f\n", eval.weightedFMeasure());
        System.out.printf("ROC AUC (weighted): %.4f\n", eval.weightedAreaUnderROC());
        System.out.println(eval.toMatrixString("Confusion Matrix"));
    }
}

